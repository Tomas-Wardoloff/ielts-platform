generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Module {
  READING
  LISTENING
  WRITING
  SPEAKING
}

enum ExerciseType {
  MULTIPLE_CHOICE
  TRUE_FALSE_NG
  YES_NO_NG
  MATCHING_INFORMATION
  MATCHING_HEADINGS
  MATCHING_FEATURES
  MATCHING_SENTENCE_ENDINGS
  SENTENCE_COMPLETION
  NOTE_TABLE_FLOWCHART_SUMMARY
  DIAGRAM_LABEL
  SHORT_ANSWER
  OPEN_WRITING
  OPEN_SPEAKING
}
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  targetBand Float?
  examDate  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempts  Attempt[]
  progress  UserProgress[]
}

model ReadingPassage {
  id         String     @id @default(cuid())
  title      String
  text       String
  source     String?
  createdAt  DateTime   @default(now())

  questions  Exercise[]
}

model Exercise {
  id           String          @id @default(cuid())
  module       Module
  type         ExerciseType
  title        String
  instructions String
  content      Json
  solution     Json
  explanation  String?
  order        Int?
  createdAt    DateTime        @default(now())

  passageId    String?
  passage      ReadingPassage? @relation(fields: [passageId], references: [id], onDelete: SetNull)
  attempts     Attempt[]
}

model Attempt {
  id          String   @id @default(cuid())
  userId      String
  exerciseId  String
  userAnswer  Json
  score       Float?
  aiFeedback  Json?
  completedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id             String   @id @default(cuid())
  userId         String
  module         Module
  totalAttempts  Int      @default(0)
  avgScore       Float?
  lastActivityAt DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
}